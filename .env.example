# SilentOps Environment Configuration
# Copy this file to .env.local and fill in your values

# Demo Mode
# Set to 'false' to disable seeded demo data; otherwise the app boots with demo fixtures
DEMO_SEED_MODE=true

# Arize Integration (Optional) — THREE surfaces:
#
# (A) Arize AX HTTP pull — lib/integrations/arize-adapter.ts
ARIZE_ENABLED=false
ARIZE_PROJECT_ID=
ARIZE_API_KEY=
#
# (B) actor-sim trace EXPORT / push (OpenTelemetry/OTLP) — actor-sim/tracing.ts
#     ARIZE_API_KEY shared with (A). No-op if SPACE_ID unset.
ARIZE_SPACE_ID=
ARIZE_OTLP_ENDPOINT=https://otlp.arize.com/v1/traces
#
# (C) Phoenix MCP — the TRACK-QUALIFYING server (@arizeai/phoenix-mcp), used by the
#     Agent Builder workflow to introspect operational data at runtime. See agent-builder/.
#     NOTE: Phoenix Cloud (app.phoenix.arize.com) is a DISTINCT sink from Arize AX —
#     send traces to Phoenix's collector for the MCP to see them. Phoenix MCP is stdio
#     (npx @arizeai/phoenix-mcp), not an HTTP URL.
PHOENIX_HOST=https://app.phoenix.arize.com
PHOENIX_API_KEY=
PHOENIX_PROJECT=silentops-actors
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/v1/traces

# MongoDB Integration (Optional)
# If disabled, the app uses in-memory storage for audit memory
# If enabled and credentials are missing, the app will fail to persist findings to MongoDB
MONGODB_ENABLED=false
MONGODB_URI=
MONGODB_DATABASE=silentops

# Gemini Reasoning Engine (Optional)
# If disabled, the Auditor agent uses a deterministic test double
# If enabled and credentials are missing, the app will fail to run live reasoning
GEMINI_ENABLED=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=

# Google Cloud Agent Builder (Optional) — orchestrates the audit workflow and calls
# the partner MCP servers (Arize MCP + MongoDB MCP) as tools. See agent-builder/.
# If disabled, the app uses native in-process orchestration (same boundaries, no MCP).
AGENT_BUILDER_ENABLED=false
AGENT_BUILDER_APP_ID=
# Base URL the Agent Builder workflow calls back for normalization (deploy-time).
APP_BASE_URL=
# Partner MCP for the workflow = Phoenix MCP (vars in section C above) + MongoDB MCP
# (uses MONGODB_URI). See agent-builder/mcp-servers.json.

# Application Port
# Cloud Run sets PORT=8080; override if running locally
PORT=3000

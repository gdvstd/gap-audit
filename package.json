  },
  "keywords": [],
  "author": "",
  "packageManager": "pnpm@10.27.0",
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.7",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
